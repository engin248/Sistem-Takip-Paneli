# ============================================================
# V-FINAL | Sistem Takip Paneli — Environment Variables
# Bu dosyayı .env.local olarak kopyalayın ve doldurun.
# cp .env.local.example .env.local
# ============================================================

# ── SUPABASE (Zorunlu) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://PROJE_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── TELEGRAM BOT (Zorunlu) ───────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFghijklmnopQRSTUVwxyz
TELEGRAM_AUTHORIZED_CHAT_IDS=123456789,987654321
TELEGRAM_NOTIFICATION_CHAT_ID=123456789

# ── AI PROVIDER ──────────────────────────────────────────────
# Ollama (local) — varsayılan
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenAI (opsiyonel, Ollama yoksa devreye girer)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# AI devre dışı bırakma (test/debug için)
# FORCE_DISABLE_OLLAMA=true
# FORCE_DISABLE_OPENAI=true

# AI timeout (ms, default: 10000)
# AI_TIMEOUT_MS=10000

# ── UYGULAMA ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AUTH (opsiyonel) ─────────────────────────────────────────
# Auth açmak için true yapın (login sayfası gerektirir)
NEXT_PUBLIC_SUPABASE_AUTH_ENABLED=false

# ── OPA / PROOF ──────────────────────────────────────────────
# OPA_POLICY_VERSION=v1.0

# ── PWA ──────────────────────────────────────────────────────
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=BEl62...

# ── BROWSERLESS (opsiyonel) ───────────────────────────────────
# BROWSERLESS_API_URL=https://chrome.browserless.io
# BROWSERLESS_API_TOKEN=your-token

# ── EXTERNAL SUPABASE (opsiyonel, ikinci proje) ──────────────
# EXTERNAL_SUPABASE_URL=https://DIGER_PROJE.supabase.co
# EXTERNAL_SUPABASE_ANON_KEY=eyJ...
