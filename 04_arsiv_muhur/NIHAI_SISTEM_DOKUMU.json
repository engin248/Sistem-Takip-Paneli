  "hata_yonetimi": {
    "motor": "errorCore.ts",
    "format": "ERR-STP001-XXX",
    "toplam_kod": 14,
    "seviyeler": ["INFO", "WARNING", "ERROR", "CRITICAL", "FATAL"],
    "uid_sistemi": "Her hata oluşumuna benzersiz UID atanır",
    "audit_entegrasyonu": "Tüm hatalar audit_logs tablosuna yazılır",
    "sozluk": "03_denetim_kanit/HATA_SOZLUGU.json",
    "kodlar": [
      "ERR-STP001-001 → SYSTEM_GENERAL (Genel sistem hatası)",
      "ERR-STP001-002 → DB_CONNECTION (Veritabanı bağlantı hatası) [CRITICAL]",
      "ERR-STP001-003 → TASK_FETCH (Görev listesi çekilemedi)",
      "ERR-STP001-004 → TASK_UPDATE (Görev durumu güncellenemedi)",
      "ERR-STP001-005 → TASK_DELETE (Görev silinemedi)",
      "ERR-STP001-006 → AUDIT_WRITE (Audit log yazılamadı)",
      "ERR-STP001-007 → AUDIT_READ (Audit log okunamadı)",
      "ERR-STP001-008 → TASK_ARCHIVE (Görev arşivlenemedi)",
      "ERR-STP001-009 → TASK_REALTIME (Realtime kanal açılamadı) [CRITICAL]",
      "ERR-STP001-010 → TASK_CREATE (Görev oluşturulamadı — Supabase)",
      "ERR-STP001-011 → TASK_CREATE_GENERAL (Görev oluşturulamadı — Genel)",
      "ERR-STP001-012 → SYSTEM_EXPORT (Sistem verisi dışa aktarılamadı)",
      "ERR-STP001-013 → CONNECTION_INVALID (Bağlantı bilgileri geçersiz) [CRITICAL]",
      "ERR-STP001-999 → UNIDENTIFIED_COLLAPSE (Tablo çökmesi) [FATAL]"
    ]
  },

