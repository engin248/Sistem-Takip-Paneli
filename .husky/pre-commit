#!/bin/sh
# ============================================================
# PRE-COMMIT HOOK — TypeScript + Unit Test Guard
# dc3f2b0 hatası (useMemo import eksikliği) tekrar etmesin
# Commit ÖNCE build + test kontrolü yapılır, hata varsa ENGELLENIR
# ============================================================

echo "🔍 Pre-commit: TypeScript kontrolü başlıyor..."

# 02_is_alani dizinine geç
cd 02_is_alani || exit 0

# 1. TypeScript type check (build'den hızlı)
npx tsc --noEmit 2>&1
TSC_EXIT=$?

if [ $TSC_EXIT -ne 0 ]; then
  echo ""
  echo "❌ COMMIT ENGELLENDİ — TypeScript hataları var!"
  echo "   Hataları düzelt, sonra tekrar commit et."
  echo ""
  exit 1
fi

echo "✅ TypeScript kontrolü geçti."

# 2. Unit test kontrolü
echo "🧪 Pre-commit: Unit testler çalıştırılıyor..."
npx vitest run 2>&1
TEST_EXIT=$?

if [ $TEST_EXIT -ne 0 ]; then
  echo ""
  echo "❌ COMMIT ENGELLENDİ — Unit testler başarısız!"
  echo "   Testleri düzelt, sonra tekrar commit et."
  echo ""
  exit 1
fi

echo "✅ Tüm kontroller geçti — commit devam ediyor."
exit 0
